# ─── API ────────────────────────────────────────────────────────────────────────
# In production this is proxied via vite.config.js to the Render backend.
# In local dev, point directly to your local API.
VITE_API_URL=http://localhost:3001/api

# ─── ANALYTICS (optional) ───────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_ANALYTICS_ENABLED=false

# ─── APP ────────────────────────────────────────────────────────────────────────
VITE_ENVIRONMENT=development
VITE_APP_NAME="ADORE Jewellery"
